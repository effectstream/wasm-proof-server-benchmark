import CompactStandardLibrary;

export ledger c: Counter;

struct HashInput {
  v: Bytes<32>;
}

// ============================================================================
// Hash chain helpers (for K=13 through K=17)
// ============================================================================

circuit hash1(input: Bytes<32>): Bytes<32> {
  return persistentHash<HashInput>(HashInput { v: input });
}

circuit hash2(input: Bytes<32>): Bytes<32> {
  return hash1(hash1(input));
}

circuit hash4(input: Bytes<32>): Bytes<32> {
  return hash2(hash2(input));
}

circuit hash8(input: Bytes<32>): Bytes<32> {
  return hash4(hash4(input));
}

circuit hash16(input: Bytes<32>): Bytes<32> {
  return hash8(hash8(input));
}

circuit hash32(input: Bytes<32>): Bytes<32> {
  return hash16(hash16(input));
}

circuit hash64(input: Bytes<32>): Bytes<32> {
  return hash32(hash32(input));
}

// ============================================================================
// K=5 through K=12: counter increments only (no hashes)
// ============================================================================

