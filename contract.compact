// ============================================================================
// K=13 through K=17: persistentHash chains
// ============================================================================

// K=13: 1 hash
export circuit test_k13(): [] {
  const h = hash1(pad(32, "k13"));
  c.increment(1);
}

// K=14: 5 hashes
export circuit test_k14(): [] {
  const h1 = hash4(pad(32, "k14"));
  const h2 = hash1(h1);
  c.increment(1);
}

// K=15: 16 hashes
export circuit test_k15(): [] {
  const h = hash16(pad(32, "k15"));
  c.increment(1);
}

// K=16: 32 hashes
export circuit test_k16(): [] {
  const h = hash32(pad(32, "k16"));
  c.increment(1);
}

// K=17: 64 hashes
export circuit test_k17(): [] {
  const h = hash64(pad(32, "k17"));
  c.increment(1);
}
